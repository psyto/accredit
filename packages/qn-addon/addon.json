{
  "name": "Fabrknt On-Chain Compliance",
  "slug": "fabrknt-onchain-compliance",
  "description": "Chain-agnostic KYC/AML compliance with on-chain enforcement. Identity reputation scores, trust assessment, route compliance, and ZK proof inputs. Solana transfer hooks + EVM contracts.",
  "version": "0.1.0",
  "author": "Fabrknt",
  "category": "compliance",
  "support": {
    "email": "support@fabrknt.com",
    "url": "https://fabrknt.com/support"
  },
  "repository": "https://github.com/psyto/accredit",
  "chains": [
    {
      "id": "solana",
      "name": "Solana"
    },
    {
      "id": "ethereum",
      "name": "Ethereum"
    }
  ],
  "networks": {
    "solana": ["mainnet-beta", "devnet"],
    "ethereum": ["mainnet", "goerli"]
  },
  "healthcheck": "/healthcheck",
  "authentication": "basic",
  "provisioning": {
    "provision": "POST /provision",
    "update": "PUT /update",
    "deactivate": "DELETE /deactivate",
    "deprovision": "DELETE /deprovision"
  },
  "plans": [
    {
      "id": "starter",
      "name": "Starter",
      "price": 0,
      "description": "Route compliance checking, ZK input preparation, pool whitelist management, and stateless trust assessment.",
      "rate_limit": {
        "requests_per_minute": 100
      },
      "features": [
        "Route compliance checking",
        "Pool whitelist management",
        "ZK witness input preparation",
        "ZK constraint verification",
        "Trust assessment (stateless)",
        "Trust comparison and profiling",
        "Trust threshold checks"
      ]
    },
    {
      "id": "pro",
      "name": "Pro",
      "price": 49,
      "description": "Full KYC reads, identity reads, batch compliance checks, plus all Starter features.",
      "rate_limit": {
        "requests_per_minute": 200
      },
      "features": [
        "All Starter features",
        "On-chain KYC entry reads",
        "Single wallet compliance checks",
        "Batch compliance checks (up to 100 wallets)",
        "On-chain identity reads (SOVEREIGN)",
        "Batch identity reads (up to 100 wallets)",
        "Per-dimension identity scores",
        "Priority support"
      ]
    }
  ],
  "endpoints": [
    {
      "method": "GET",
      "path": "/v1/kyc/:wallet",
      "description": "Read whitelist entry for a wallet",
      "plan": "pro"
    },
    {
      "method": "POST",
      "path": "/v1/kyc/check",
      "description": "Check single wallet compliance",
      "plan": "pro"
    },
    {
      "method": "POST",
      "path": "/v1/kyc/batch",
      "description": "Batch compliance check (max 100 wallets)",
      "plan": "pro"
    },
    {
      "method": "GET",
      "path": "/v1/identity/:wallet",
      "description": "Read SOVEREIGN identity scores, tier, and confidence",
      "plan": "pro"
    },
    {
      "method": "POST",
      "path": "/v1/identity/batch",
      "description": "Batch identity read (max 100 wallets)",
      "plan": "pro"
    },
    {
      "method": "GET",
      "path": "/v1/identity/:wallet/dimension/:dimension",
      "description": "Read a single dimension score for a wallet",
      "plan": "pro"
    },
    {
      "method": "POST",
      "path": "/v1/trust/assess",
      "description": "Stateless trust assessment from SOVEREIGN scores",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/trust/compare",
      "description": "Compare trust profiles of two wallets",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/trust/threshold",
      "description": "Check if scores meet a minimum threshold",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/trust/profile",
      "description": "Analyze score profile: strongest, weakest, ranking",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/route/check",
      "description": "Check route plan compliance against pool whitelist",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/route/pools",
      "description": "Batch check pool keys against whitelist",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/route/whitelist/add",
      "description": "Add pool to whitelist",
      "plan": "starter"
    },
    {
      "method": "DELETE",
      "path": "/v1/route/whitelist/:ammKey",
      "description": "Remove pool from whitelist",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/zk/prepare",
      "description": "Generate witness inputs for ZK compliance circuit",
      "plan": "starter"
    },
    {
      "method": "POST",
      "path": "/v1/zk/verify-inputs",
      "description": "Stateless verification of compliance constraint inputs",
      "plan": "starter"
    }
  ]
}
